      <column caption='District Performance' datatype='string' name='[Calculation_0053642285326338]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0620715275128833]=&quot;Below Average&quot; AND MAX ([Calculation_0053642284990465])&gt; 5000 THEN &quot;High Priority&quot; ELSE &quot;Monitor&quot; End' />
      </column>
      <column caption='Total prod sub' datatype='real' name='[Calculation_0053642287247363]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN([M_Prod_Tot_S]) + ZN([S_Prod_Tot_S])' />
